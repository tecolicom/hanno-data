#!/usr/bin/env python3
"""cal-oshirase-fetch — 飯能市公式サイト「新着情報」RSS を YAML 化。

Source: https://www.city.hanno.lg.jp/cgi-bin/feed.php?siteNew=1&displayCount=50&displayRange=90&includeShortcut=0

RSS 1.0 (RDF) を取得し、各 <item> を 1 終日イベント に変換する。

## 2 つの動作モード

### incremental mode (デフォルト、cron 用)
- UID:     oshirase-<page-id>-<hash6>@hanno.city.tecoli.com
- dtstart: fetched_at (= 取得日、JST)
- 「市の RSS フィードに新着掲載 / または内容が変わった」たびに **別の** YAML を生成。
- 同じ (page_id, content_hash) の YAML が既にあれば skip。
- 過去の YAML は触らず保持 → カレンダー上に「いつ我々が認識したか」「内容変更の履歴」が残る。
- app トップの「今日以降 7 日」ウィンドウに自然に現れる (= 今日 fetched の dtstart=今日)。
- dc:date (市の公開日) は source.publish_date に保持。

### once-per-page mode (legacy、--once-per-page で有効)
- UID:     oshirase-<page-id>@hanno.city.tecoli.com  (page-id は URL 末尾の数字)
- dtstart: dc:date (= 市の公開日)
- 1 page = 1 YAML。既存 UID と同じなら skip、content_hash 差分なら上書き。
- 新規街の onboarding / 過去分 backfill 用。

## description 生成 (両モード共通)

本文長に応じて 3 方式:
- 抽出失敗 (<50字):    URL のみ                    (method=url-only)
- 50-400字:           本文全文 + URL              (method=full)
- >400字:             LLM (Claude Haiku) 要約 + URL (method=llm-haiku-4-5)
                      ※ ANTHROPIC_API_KEY 必須。API 失敗時は full にフォールバック。
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.request
from datetime import date as _date, datetime, timezone, timedelta

JST = timezone(timedelta(hours=9))

try:
    import httpx  # LLM 要約用 (>400字 で必要)
except ImportError:
    httpx = None  # type: ignore


USER_AGENT = "myhanno-calendar-fetcher/0.1 (+https://city.tecoli.com)"
UID_NAMESPACE = "hanno.city.tecoli.com"
DEFAULT_UID_PREFIX = "oshirase"
SOURCE_TYPE = "city-hanno-oshirase"
SUMMARY_PREFIX = "ℹ️ "
FEED_URL = (
    "https://www.city.hanno.lg.jp/cgi-bin/feed.php"
    "?siteNew=1&displayCount=50&displayRange=90&includeShortcut=0"
)
URL_HOST_ALLOWLIST = "www.city.hanno.lg.jp"

# 本文長に応じた処理しきい値
MIN_BODY_CHARS = 50    # これ未満なら抽出失敗扱い → URL のみ
FULL_TEXT_THRESHOLD = 400  # これ以下は全文掲載、超は LLM 要約

# description 整形フォーマットのバージョン. wrapper/disclaimer 変更時にインクリ
# メントすると content_hash が変わり、既存 YAML が再生成される.
# docs/ai-content-policy.md 参照.
# v1: 初版
# v2: AI disclaimer 追加 (LLM要約の冒頭)
# v3: LLM 出力から Markdown 記法を除去 (Google Calendar は plain text 扱い)
# v4: 中止/終了/延期等の最新ステータスを要約冒頭に配置するよう prompt 改訂
# v5: ステータス変更続報 (申込終了等) では要約を短く保つよう prompt 追加
# v6: 主目的判定をタイトル base に変更 (本文の「(終了)」注記に引きずられない)
# v7: 主目的判定を時制 + actionability base に変更
#     (「停止します」future = full detail / 「受付終了」past = brief)
DESCRIPTION_FORMAT_VERSION = 7

# AI 要約に付ける固定 disclaimer (冒頭配置). docs/ai-content-policy.md 参照.
AI_DISCLAIMER = "AI による要約 (正確な情報は元記事をご確認ください)"

# LLM (Claude Haiku 4.5) 設定
LLM_MODEL = "claude-haiku-4-5"
LLM_MAX_TOKENS = 1024
LLM_SYSTEM_PROMPT = """あなたは飯能市公式サイトのお知らせ記事を、市民向けカレンダーに掲載するために短く要約するアシスタントです。

要約方針:
- 全体で 200〜400 字程度の日本語。
- 日時・期間・場所・対象者・料金・申込締切・申込方法など、市民の行動に関わる事実は省略しない。本文に書かれていないことは書かない (推測禁止)。
- 記事の **主目的を判定** してから要約を組み立ててください。判定軸は「時制 (過去/未来)」と「アクション可能性」:
  - **過去のステータス変更告知** (例: タイトル/本文が「受付終了しました」「中止しました」「定員に達しました」等の事後報告): 要約を **100〜150 字程度に短く** 保ち、ステータス変更 + 対象イベント名 + 過去の日付のみ。日時/場所/対象/料金/講師等の詳細は省略 (既に応募できない情報は冗長)。
  - **未来のステータス変更予告** (例: 「停止します」「中止します」「変更します」等のこれから起きる予告): 通常のイベント告知と同様に、影響期間/対象/代替手段/再開予定など **actionable な情報を含めた完全な要約** を作る (市民は事前に準備や代替行動を検討する必要があるため)。
  - **通常の告知** (タイトルに status 語が無い、開催/案内/募集/資料公開/制度説明等): 主目的の情報を冒頭に。本文中に「(終了)」のような注記があっても、それは背景情報なので末尾近くに簡潔に触れる程度に留める。
  - **どの場合も、本文に明記されたステータス情報は必ず要約に含める**。冒頭か末尾かは上記の主目的判定で決める。市民が誤って「もう参加できない / 日程が変わった」イベントに行こうとしないように注意。
- 日付や金額は本文表記をそのまま (令和8年5月31日 等)。
- 出だしに「お知らせ:」「概要:」のような冗語は不要。本題から始める。
- 末尾に URL や「詳細は〜」を付けない。呼出側で付与する。
- **Markdown 記法 (**太字**、*斜体*、# 見出し、- リスト、`code`、リンク [text](url) 等) は一切使わないでください**。出力先は Google カレンダーの予定欄で、Markdown は literal なテキストとして表示されてしまいます。
- 構造化したい場合は改行と全角記号で表現してください: 箇条書きは行頭「・」、見出しは「【見出し】」、強調が必要な場合は「」または 【 】 を使う。
- 要約だけ返す。前置きや「以下は要約です」等の説明は不要。
"""


def fetch(url: str) -> str:
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")


def safe_url(url: str) -> bool:
    return url.startswith(f"https://{URL_HOST_ALLOWLIST}/")


# ---------- RSS パース ----------


_ITEM_RE = re.compile(r"<item\b[^>]*>([\s\S]*?)</item>", re.IGNORECASE)
_TITLE_RE = re.compile(r"<title>([\s\S]*?)</title>", re.IGNORECASE)
_LINK_RE = re.compile(r"<link>([\s\S]*?)</link>", re.IGNORECASE)
_DATE_RE = re.compile(r"<dc:date>(\d{4})-(\d{2})-(\d{2})T", re.IGNORECASE)
_PAGE_ID_RE = re.compile(r"/(\d+)\.html$")


def parse_items(xml: str) -> list[dict]:
    out: list[dict] = []
    for m in _ITEM_RE.finditer(xml):
        body = m.group(1)
        t = _TITLE_RE.search(body)
        l = _LINK_RE.search(body)
        d = _DATE_RE.search(body)
        if not (t and l and d):
            continue
        title = re.sub(r"\s+", " ", t.group(1)).strip()
        link = l.group(1).strip()
        yyyy, mm, dd = d.group(1), d.group(2), d.group(3)
        try:
            _date(int(yyyy), int(mm), int(dd))
        except ValueError:
            continue
        pid_m = _PAGE_ID_RE.search(link)
        if not pid_m:
            continue
        out.append({
            "title": title,
            "url": link,
            "date": f"{yyyy}-{mm}-{dd}",
            "page_id": pid_m.group(1),
        })
    return out


# ---------- 本文抽出 ----------


def _strip_html(s: str) -> str:
    """HTML タグ + 主要 entity を素のテキストに."""
    s = re.sub(r"<br\s*/?>", "\n", s, flags=re.I)
    s = re.sub(r"</p\s*>", "\n\n", s, flags=re.I)
    s = re.sub(r"</li\s*>", "\n", s, flags=re.I)
    s = re.sub(r"</h[1-6]\s*>", "\n\n", s, flags=re.I)
    s = re.sub(r"<[^>]+>", "", s)
    s = s.replace("&nbsp;", " ").replace("&amp;", "&")
    s = s.replace("&lt;", "<").replace("&gt;", ">").replace("&quot;", '"')
    return s


def _normalize_body(text: str) -> str:
    """段落間 1 空行、行頭空白除去、末尾空白除去."""
    lines = [ln.rstrip() for ln in text.split("\n")]
    lines = [re.sub(r"^[ 　]+", "", ln) for ln in lines]
    out: list[str] = []
    blank_run = 0
    for ln in lines:
        if ln == "":
            blank_run += 1
            if blank_run <= 1:
                out.append(ln)
        else:
            blank_run = 0
            out.append(ln)
    return "\n".join(out).strip()


def extract_body(html: str) -> str:
    """記事 HTML から本文テキストを抽出.

    `<div id="contents-in">` から `<div class="toiawase">` 直前まで。
    page-number-display ブロックと figure を除外。h2 (head-title) も含めて、
    複数セクション構造 (h2 + wysiwyg の繰り返し) のお知らせに対応。
    """
    m = re.search(r'<div id="contents-in"[^>]*>([\s\S]*?)<!--\s*//#contents-in', html)
    if not m:
        return ""
    block = m.group(1)
    # toiawase (お問い合わせ先) を境界として除去
    block = re.sub(r'<div class="toiawase">[\s\S]*$', "", block)
    # page-id 表示 (本文ではない)
    block = re.sub(r'<div class="page-number-display">[\s\S]*?</div>\s*</div>', "", block)
    # figure / img (本文意味ほぼ無し、altのみ拾うのは複雑なので除外)
    block = re.sub(r"<figure[^>]*>[\s\S]*?</figure>", "", block)
    # h2 は内容を "## " 付きで残す (head-title span 入れ子を一旦テキスト化)
    def _h2_repl(m: re.Match) -> str:
        inner = re.sub(r"<[^>]+>", "", m.group(1))
        inner = re.sub(r"\s+", " ", inner).strip()
        return f"\n\n## {inner}\n\n" if inner else "\n\n"
    block = re.sub(r"<h2[^>]*>([\s\S]*?)</h2>", _h2_repl, block)
    text = _strip_html(block)
    return _normalize_body(text)


# ---------- LLM 要約 ----------


def strip_markdown(text: str) -> str:
    """LLM が混入させた Markdown を plain text に変換.

    Google Calendar の description は Markdown を解釈しない (literal 表示) ため、
    プロンプトで「使うな」と指示した上で、保険として実行する.
    """
    if not text:
        return text
    # **bold**, __bold__ → bold (非貪欲)
    text = re.sub(r"\*\*([^*\n]+?)\*\*", r"\1", text)
    text = re.sub(r"__([^_\n]+?)__", r"\1", text)
    # *italic*, _italic_ → italic (改行を跨がない、ペアでない単独 * は触らない)
    text = re.sub(r"(?<!\*)\*(?!\*)([^*\n]+?)(?<!\*)\*(?!\*)", r"\1", text)
    text = re.sub(r"(?<!_)_(?!_)([^_\n]+?)(?<!_)_(?!_)", r"\1", text)
    # 行頭 #/##/### 見出し記号 → 削除
    text = re.sub(r"(?m)^#{1,6}\s+", "", text)
    # 行頭 - / * リスト → 全角中黒
    text = re.sub(r"(?m)^[ \t]*[-*]\s+", "・", text)
    # `code` → code
    text = re.sub(r"`([^`\n]+?)`", r"\1", text)
    # [text](url) → text (url の意味は本文外で扱う)
    text = re.sub(r"\[([^\]\n]+)\]\((https?://[^)\s]+)\)", r"\1 (\2)", text)
    return text


def summarize_with_llm(title: str, body: str) -> str | None:
    """Claude Haiku 4.5 で要約。失敗時 None を返す (呼出側で fallback)."""
    if httpx is None:
        print("  WARN: httpx not installed, skipping LLM summary", file=sys.stderr)
        return None
    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print("  WARN: ANTHROPIC_API_KEY not set, skipping LLM summary", file=sys.stderr)
        return None
    if not body or len(body) < MIN_BODY_CHARS:
        # 安全装置: 空 body で LLM を呼ばない (ハルシネーション防止)
        return None
    try:
        r = httpx.post(
            "https://api.anthropic.com/v1/messages",
            headers={
                "x-api-key": api_key,
                "anthropic-version": "2023-06-01",
                "content-type": "application/json",
            },
            json={
                "model": LLM_MODEL,
                "max_tokens": LLM_MAX_TOKENS,
                "system": LLM_SYSTEM_PROMPT,
                "messages": [{"role": "user", "content": f"# {title}\n\n{body}"}],
            },
            timeout=60,
        )
        r.raise_for_status()
        data = r.json()
        return strip_markdown(data["content"][0]["text"].strip())
    except Exception as e:
        print(f"  WARN: LLM summary failed: {e}", file=sys.stderr)
        return None


# ---------- description 組立 ----------


def _llm_available() -> bool:
    """この環境で LLM 呼出が可能か (CI 等で httpx 無 / API key 無 を事前検知)."""
    return httpx is not None and bool(os.environ.get("ANTHROPIC_API_KEY"))


def _materialize_description(body: str, method: str, title: str, article_url: str) -> str:
    """method に応じて description を組み立てる (LLM 呼出はこの中で発生).

    method は事前に環境 (LLM 利用可否) を踏まえて決定される前提のため、
    ここで再 fallback は起きない. LLM 呼出が想定外に失敗した場合は full
    にフォールバックするが、その場合 method 表記と description が乖離する
    点には注意.
    """
    suffix = f"飯能市公式サイト 新着情報: {article_url}"
    if method == "url-only":
        return suffix
    if method == "full":
        return f"{body}\n\n{suffix}"
    if method == "llm-haiku-4-5":
        summary = summarize_with_llm(title, body)
        if summary:
            return f"{AI_DISCLAIMER}\n\n{summary}\n\n{suffix}"
        # 例外的失敗 (network/rate limit 等). full にフォールバックして
        # 当該 yaml は次回再評価される (hash は llm-haiku-4-5 で書かれるため、
        # 次回 body 不変でも intended_hash 一致 → skip にならず再試行される設計).
        print(f"  WARN: LLM unexpected failure, fallback to full text: {article_url}", file=sys.stderr)
        return f"{body}\n\n{suffix}"
    return suffix


# ---------- YAML 出力 ----------


def yaml_escape_str(s: str) -> str:
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def yaml_block_scalar(s: str, indent: int = 2) -> str:
    pad = " " * indent
    lines = s.split("\n")
    head, body = ("|", lines[:-1] if lines and lines[-1] == "" else lines) if s.endswith("\n") else ("|-", lines)
    return head + "\n" + "\n".join(pad + ln for ln in body)


def build_yaml_doc(uid: str, item_url: str, page_id: str, title: str, date_str: str,
                   description: str, method: str,
                   content_hash: str, fetched_at: str | None,
                   publish_date: str | None = None) -> str:
    lines: list[str] = []
    lines.append(f"uid: {yaml_escape_str(uid)}")
    lines.append(f"summary: {yaml_escape_str(SUMMARY_PREFIX + title)}")
    lines.append(f"url: {yaml_escape_str(item_url)}")
    lines.append(f"dtstart: {yaml_escape_str(date_str)}")
    lines.append(f"dtend: {yaml_escape_str(date_str)}")
    lines.append("description: " + yaml_block_scalar(description, indent=2))
    lines.append("")
    lines.append("render:")
    lines.append("  gcal:")
    lines.append("    mode: single-allday")
    lines.append("")
    lines.append("source:")
    lines.append(f"  type: {SOURCE_TYPE}")
    lines.append(f"  id: {yaml_escape_str(page_id)}")
    lines.append(f"  url: {yaml_escape_str(item_url)}")
    ts = fetched_at or (datetime.utcnow().isoformat() + "Z")
    lines.append(f"  fetched_at: {yaml_escape_str(ts)}")
    lines.append(f"  content_hash: {yaml_escape_str('sha256-' + content_hash)}")
    lines.append(f"  summary_method: {yaml_escape_str(method)}")
    # incremental mode で dtstart を fetched_at に置き換えた場合に、元の公開日 (RSS dc:date)
    # を後追いできるよう保持。once-per-page mode では dtstart == publish_date なので省略。
    if publish_date and publish_date != date_str:
        lines.append(f"  publish_date: {yaml_escape_str(publish_date)}")
    return "\n".join(lines) + "\n"


def output_path_for(out_dir: str, uid: str, date_str: str) -> str:
    year_part = date_str[:4]
    md = date_str[5:10]
    fname = f"{md}_{uid.split('@')[0]}.yaml"
    return os.path.join(out_dir, year_part, fname)


# ---------- main ----------


def _find_existing_by_uid(events_dir: str, uid: str) -> str | None:
    import glob
    pattern = os.path.join(events_dir, "**", "*.yaml")
    for path in glob.glob(pattern, recursive=True):
        try:
            with open(path, "r", encoding="utf-8") as f:
                head = f.read(4096)
        except Exception:
            continue
        if uid in head:
            return path
    return None


def _existing_content_hashes(events_dir: str, uid_prefix: str) -> set[tuple[str, str]]:
    """既存 YAML から (page_id, content_hash) ペアを集める。

    incremental mode の skip 判定に使う。once-per-page と incremental の両形式の
    UID から page_id を抽出する: `oshirase-<pid>@...` / `oshirase-<pid>-<hash6>@...`。
    """
    import glob
    pattern = os.path.join(events_dir, "**", "*.yaml")
    result: set[tuple[str, str]] = set()
    pid_re = re.compile(rf"^{re.escape(uid_prefix)}-(\d+)(?:-[A-Za-z0-9]+)?@")
    for path in glob.glob(pattern, recursive=True):
        uid = _read_yaml_scalar(path, "uid")
        if not uid:
            continue
        m = pid_re.match(uid)
        if not m:
            continue
        page_id = m.group(1)
        ch = _read_yaml_scalar(path, "content_hash")
        if not ch:
            continue
        if ch.startswith("sha256-"):
            ch = ch[len("sha256-"):]
        result.add((page_id, ch))
    return result


def _read_yaml_scalar(path: str, key: str) -> str | None:
    try:
        with open(path, "r", encoding="utf-8") as f:
            for ln in f:
                m = re.match(r"^\s*" + re.escape(key) + r":\s*\"([^\"]*)\"\s*$", ln)
                if m:
                    return m.group(1)
    except Exception:
        return None
    return None


def _rewrite_yaml_scalar(path: str, key: str, new_value: str) -> bool:
    """YAML の scalar key (例: content_hash) を in-place 書き換え。

    `--rehash-only` 用の最小限の sed 相当。マッチする最初の行を `\"new_value\"` で
    置換する。インデントと空白は維持。書き換えに成功したら True。
    """
    pat = re.compile(r"^(\s*" + re.escape(key) + r":\s*)\"[^\"]*\"\s*$")
    try:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()
    except Exception:
        return False
    updated = False
    for i, ln in enumerate(lines):
        m = pat.match(ln)
        if m:
            lines[i] = f"{m.group(1)}{yaml_escape_str(new_value)}\n"
            updated = True
            break
    if not updated:
        return False
    try:
        with open(path, "w", encoding="utf-8") as f:
            f.writelines(lines)
        return True
    except Exception:
        return False


def main() -> None:
    here = os.path.dirname(os.path.abspath(__file__))
    default_out_dir = os.path.join(here, "..", "events")

    ap = argparse.ArgumentParser(description="飯能市公式サイト 新着情報 → YAML")
    ap.add_argument("--out-dir", default=default_out_dir)
    ap.add_argument("--uid-prefix", default=DEFAULT_UID_PREFIX)
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--refetch-existing", action="store_true",
                    help="(once-per-page) 既存 YAML も記事 fetch して content_hash 不一致なら上書き")
    ap.add_argument("--once-per-page", action="store_true",
                    help="legacy mode: 1 page = 1 YAML、dtstart = dc:date。"
                         "新規街 onboarding / 過去分 backfill 用。"
                         "デフォルトは incremental mode (新規・内容変化ごとに別 YAML、dtstart=今日)")
    ap.add_argument("--rehash-only", action="store_true",
                    help="migration 用: 既存 YAML の content_hash フィールドだけ現 format_version "
                         "に再計算して in-place 更新。description は触らない (LLM 呼出なし)。"
                         "--once-per-page と組み合わせて使う。")
    ap.add_argument("--min-items", type=int, default=0,
                    help="抽出 item 数がこれ未満なら exit 2 (default: 0)")
    args = ap.parse_args()

    print(f"Fetching {FEED_URL}", file=sys.stderr)
    xml = fetch(FEED_URL)
    items = parse_items(xml)
    print(f"Parsed {len(items)} items", file=sys.stderr)

    # --refetch-existing は once-per-page mode 専用 (incremental mode では意味を持たない)
    if args.refetch_existing and args.once_per_page:
        items = _augment_with_existing(items, args.out_dir, args.uid_prefix)
        print(f"  with existing YAMLs: {len(items)} items total", file=sys.stderr)

    # incremental mode 用: 既存 YAML の (page_id, content_hash) を pre-scan して set 化
    existing_hashes: set[tuple[str, str]] = set()
    if not args.once_per_page:
        existing_hashes = _existing_content_hashes(args.out_dir, args.uid_prefix)

    today_jst = datetime.now(JST).strftime("%Y-%m-%d")

    written = 0
    skipped = 0
    unchanged = 0
    for it in items:
        if not safe_url(it["url"]):
            continue

        # once-per-page mode: 既存 UID チェックを記事 fetch 前に行う (polite)
        if args.once_per_page:
            uid = f"{args.uid_prefix}-{it['page_id']}@{UID_NAMESPACE}"
            existing_path = _find_existing_by_uid(args.out_dir, uid)
            if existing_path and not args.refetch_existing:
                skipped += 1
                continue
        else:
            uid = None  # incremental: hash 計算後に決定
            existing_path = None

        # 記事 fetch → body 抽出 + method 判定 (LLM 呼出はまだ)
        try:
            article_html = fetch(it["url"])
        except Exception as e:
            print(f"  ERROR fetching {it['url']}: {e}", file=sys.stderr)
            continue
        body = extract_body(article_html)
        if not body or len(body) < MIN_BODY_CHARS:
            method = "url-only"
        elif len(body) <= FULL_TEXT_THRESHOLD:
            method = "full"
        elif _llm_available():
            method = "llm-haiku-4-5"
        else:
            # CI 等で LLM 環境が無い場合、長文も full text で書く. method を full
            # にしておけば content_hash も full になり、後でローカルから LLM 付きで
            # 再実行すると method=llm-haiku-4-5 で hash が変わって再生成が走る.
            method = "full"

        # 入力ベースの content_hash (= body + method + format_version)。
        # LLM 出力は含めない → LLM 非決定性に関わらず idempotent。
        # body / method / format_version のどれかが変わった時だけ description 再生成。
        canonical = json.dumps(
            {"title": it["title"], "date": it["date"], "body": body, "method": method,
             "format_version": DESCRIPTION_FORMAT_VERSION},
            ensure_ascii=False, sort_keys=True,
        )
        content_hash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:16]

        if args.once_per_page:
            # legacy: 既存 YAML があり content_hash 一致なら skip
            if existing_path:
                old_hash = _read_yaml_scalar(existing_path, "content_hash")
                if old_hash == f"sha256-{content_hash}":
                    unchanged += 1
                    continue
            # --rehash-only: description は再生成せず、既存 YAML の content_hash
            # フィールドだけ in-place で書き換える (LLM 呼出なし)
            if args.rehash_only and existing_path:
                if args.dry_run:
                    print(f"# REHASH {existing_path}: {old_hash} → sha256-{content_hash}")
                    written += 1
                    continue
                _rewrite_yaml_scalar(existing_path, "content_hash",
                                     f"sha256-{content_hash}")
                print(f"  REHASH {existing_path}", file=sys.stderr)
                written += 1
                continue
            dtstart = it["date"]                 # dc:date
            publish_date = None                  # dtstart と同じなので省略
        else:
            # incremental: (page_id, content_hash) が既知なら skip (新規 / 変更 のみ書く)
            if (it["page_id"], content_hash) in existing_hashes:
                unchanged += 1
                continue
            uid = f"{args.uid_prefix}-{it['page_id']}-{content_hash[:6]}@{UID_NAMESPACE}"
            dtstart = today_jst                  # 今日 JST
            publish_date = it["date"]            # dc:date を保持

        # description を実際に組み立てる (LLM 呼出はここで初めて発生)
        description = _materialize_description(body, method, it["title"], it["url"])
        doc = build_yaml_doc(uid, it["url"], it["page_id"], it["title"], dtstart,
                             description, method, content_hash, None,
                             publish_date=publish_date)
        out_path = output_path_for(args.out_dir, uid, dtstart)

        if args.dry_run:
            print(f"# === {os.path.relpath(out_path, args.out_dir)} === [method={method}]")
            print(doc)
            continue

        if existing_path and os.path.abspath(existing_path) != os.path.abspath(out_path):
            os.remove(existing_path)
        os.makedirs(os.path.dirname(out_path), exist_ok=True)
        with open(out_path, "w", encoding="utf-8") as f:
            f.write(doc)
        # incremental では次の loop iter 内でも自身を skip 対象にできるよう set 更新
        if not args.once_per_page:
            existing_hashes.add((it["page_id"], content_hash))
        verb = "UPDATED" if existing_path else "WROTE"
        print(f"  {verb} [{method}] {out_path}", file=sys.stderr)
        written += 1

    mode_label = "once-per-page" if args.once_per_page else "incremental"
    print(f"Done [{mode_label}]. items written={written}  unchanged={unchanged}  skipped (existing)={skipped}",
          file=sys.stderr)

    if (written + skipped) < args.min_items and not args.dry_run:
        print(f"FAIL: items ({written + skipped}) < --min-items ({args.min_items}).",
              file=sys.stderr)
        sys.exit(2)


def _augment_with_existing(items: list[dict], out_dir: str, uid_prefix: str) -> list[dict]:
    """既存 oshirase YAML を items に追加 (RSS の 90 日窓を超えた backfill 用).

    既に items に含まれる page_id は skip。
    """
    import glob
    seen = {it["page_id"] for it in items}
    pattern = os.path.join(out_dir, "**", "*.yaml")
    extra: list[dict] = []
    for path in sorted(glob.glob(pattern, recursive=True)):
        uid = _read_yaml_scalar(path, "uid")
        if not uid or not uid.startswith(f"{uid_prefix}-"):
            continue
        page_id_m = re.match(rf"{re.escape(uid_prefix)}-(\d+)@", uid)
        if not page_id_m:
            continue
        page_id = page_id_m.group(1)
        if page_id in seen:
            continue
        url = _read_yaml_scalar(path, "url")
        date = _read_yaml_scalar(path, "dtstart")
        title_full = _read_yaml_scalar(path, "summary") or ""
        title = title_full[len(SUMMARY_PREFIX):] if title_full.startswith(SUMMARY_PREFIX) else title_full
        if not (url and date and title):
            continue
        extra.append({"title": title, "url": url, "date": date, "page_id": page_id})
        seen.add(page_id)
    return items + extra


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""cal-shicho-blog-fetch — 飯能市長ブログ「市政一直線」を YAML 化。

Source: https://www.city.hanno.lg.jp/shiseijoho/shichoshitsu/shichoblog/

階層:
  top                              shichoblog/index.html
  year (令和N年)                   shichoblog/shisei<YYYY>/index.html
  month (令和N年M月)               shichoblog/shisei<YYYY>/shisei<YYYYMM>/index.html
  article (各記事、市長が参加した行事等)  shichoblog/shisei<YYYY>/shisei<YYYYMM>/<page-id>.html

LLM 不使用。当年度の全月を巡回し、新規 article の YAML を生成する。
既存 YAML がある article は再 fetch しない (polite + 速い)。
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.request
from datetime import date as _date, datetime

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _lib import read_yaml_scalar


USER_AGENT = "myhanno-calendar-fetcher/0.1 (+https://city.tecoli.com)"
UID_NAMESPACE = "hanno.city.tecoli.com"
DEFAULT_UID_PREFIX = "shicho-blog"
SOURCE_TYPE = "city-hanno-shicho-blog"
SUMMARY_PREFIX = "📝 市長："
TOP_URL = "https://www.city.hanno.lg.jp/shiseijoho/shichoshitsu/shichoblog/index.html"
URL_HOST_ALLOWLIST = "www.city.hanno.lg.jp"
URL_PATH_PREFIX = "/shiseijoho/shichoshitsu/shichoblog/"


def fetch_html(url: str) -> str:
    req = urllib.request.Request(url, headers={"User-Agent": USER_AGENT})
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")


def safe_url(url: str) -> bool:
    """allowlist 内の URL のみ許可."""
    return url.startswith(f"https://{URL_HOST_ALLOWLIST}{URL_PATH_PREFIX}")


# ---------- index 巡回 ----------


def find_year_page(top_html: str, reiwa_y: int) -> str | None:
    """top index ページから「市政一直線（令和N年）」へのリンクを探す.

    新しいページは shisei<YYYY>/, 古いものは 1/, 2/ のような番号 path もある。
    令和8年=2026 → /shisei2026/
    """
    label = f"令和{reiwa_y}年"
    pattern = (
        r'href="(https?://[^"]+/shichoblog/[^"]+/index\.html)"[^>]*>市政一直線[（(]\s*'
        + re.escape(label) + r'\s*[）)]'
    )
    m = re.search(pattern, top_html)
    return m.group(1) if m else None


def find_month_pages(year_html: str, reiwa_y: int) -> list[tuple[int, str]]:
    """year index ページから各月へのリンクを取得.

    戻り値: [(month, url), ...] 月昇順
    """
    out: list[tuple[int, str]] = []
    pattern = (
        r'href="(https?://[^"]+/shichoblog/[^"]+/index\.html)"[^>]*>市長ブログ[（(]\s*'
        + re.escape(f"令和{reiwa_y}年") + r'(\d+)月\s*[）)]'
    )
    for m in re.finditer(pattern, year_html):
        url, mm = m.group(1), int(m.group(2))
        out.append((mm, url))
    out.sort()
    return out


def find_article_links(month_html: str) -> list[tuple[str, str]]:
    """month index ページから各記事へのリンクを取得.

    戻り値: [(url, title), ...]
    """
    out: list[tuple[str, str]] = []
    # href=".../shichoblog/<year>/<month>/<digits>.html">記事タイトル</a>
    pattern = r'href="(https?://[^"]+/shichoblog/[^"]+/(\d+)\.html)"[^>]*>([^<]{3,})</a>'
    seen: set[str] = set()
    for m in re.finditer(pattern, month_html):
        url, title = m.group(1), m.group(3).strip()
        if url in seen:
            continue
        seen.add(url)
        out.append((url, title))
    return out


# ---------- article parse ----------


_DATE_RE = re.compile(r"(\d{4})年(\d{1,2})月(\d{1,2})日")

# 本文抽出のしきい値・パラメータ
BODY_FULL_THRESHOLD = 800   # この字数以下なら全文掲載
BODY_EXCERPT_TARGET = 600   # 超過時の目標抜粋字数


def _strip_html(s: str) -> str:
    """HTML タグ + 主要 entity を素のテキストに."""
    s = re.sub(r"<br\s*/?>", "\n", s, flags=re.I)
    s = re.sub(r"</p\s*>", "\n\n", s, flags=re.I)
    s = re.sub(r"<[^>]+>", "", s)
    s = s.replace("&nbsp;", " ").replace("&amp;", "&")
    s = s.replace("&lt;", "<").replace("&gt;", ">").replace("&quot;", '"')
    return s


def _normalize_body(text: str) -> str:
    """段落間 1 空行、行頭空白除去、末尾空白除去."""
    lines = [ln.rstrip() for ln in text.split("\n")]
    # 行頭の連続空白は段落字下げの装飾なので除去
    lines = [re.sub(r"^[ 　]+", "", ln) for ln in lines]
    # 3 行以上の空行は 2 行に圧縮 (段落区切り = 1 空行)
    out: list[str] = []
    blank_run = 0
    for ln in lines:
        if ln == "":
            blank_run += 1
            if blank_run <= 1:
                out.append(ln)
        else:
            blank_run = 0
            out.append(ln)
    return "\n".join(out).strip()


def extract_body(html: str) -> str:
    """記事 HTML から本文テキストを抽出.

    `<div class="free-layout-area">` 配下、`<div class="toiawase">` (お問い合わせ先)
    手前まで。h2 の日付見出しは除外 (title 由来情報なので冗長)。
    """
    m = re.search(r'<div class="free-layout-area">([\s\S]*?)(?=<div class="toiawase">|</article>)', html)
    if not m:
        return ""
    block = m.group(1)
    # h2 (日付見出し) は除外
    block = re.sub(r"<h2[^>]*>[\s\S]*?</h2>", "", block)
    # figure / img は除外
    block = re.sub(r"<figure[^>]*>[\s\S]*?</figure>", "", block)
    text = _strip_html(block)
    return _normalize_body(text)


def truncate_body(body: str, full_threshold: int = BODY_FULL_THRESHOLD,
                  excerpt_target: int = BODY_EXCERPT_TARGET) -> tuple[str, bool]:
    """長さに応じて全文 or 抜粋を返す.

    戻り値: (text, truncated)
    """
    if len(body) <= full_threshold:
        return body, False

    # 段落境界優先
    paragraphs = body.split("\n\n")
    acc: list[str] = []
    total = 0
    for p in paragraphs:
        if acc and total + len(p) + 2 > excerpt_target:
            break
        acc.append(p)
        total += len(p) + 2
    excerpt = "\n\n".join(acc).strip()

    # 段落 1 個ですでに長過ぎる → 句点で切る
    if not excerpt or len(excerpt) > excerpt_target * 1.5:
        first = paragraphs[0]
        cut = -1
        for i in range(min(len(first), excerpt_target + 100), 0, -1):
            if first[i - 1] == "。":
                cut = i
                break
        if cut > 0:
            excerpt = first[:cut]
        else:
            excerpt = first[:excerpt_target]
    return excerpt + "…", True


def parse_article(html: str) -> dict | None:
    """h1 + 更新日 + 本文を抽出して dict 返す.

    戻り値: {"title": str, "date": "YYYY-MM-DD", "body": str, "body_truncated": bool},
            失敗時 (title/date 取れない時) None
    """
    # h1 (空のものをスキップ、最初の意味あるものを採用)
    title: str | None = None
    for m in re.finditer(r"<h1[^>]*>([\s\S]*?)</h1>", html):
        t = re.sub(r"<[^>]+>", "", m.group(1))
        t = re.sub(r"\s+", " ", t).strip()
        if t:
            title = t
            break
    if not title:
        return None

    # 更新日 (本文上部に「更新日：YYYY年MM月DD日」)
    dm = _DATE_RE.search(html)
    if not dm:
        return None
    yyyy, mm, dd = int(dm.group(1)), int(dm.group(2)), int(dm.group(3))
    try:
        _date(yyyy, mm, dd)
    except ValueError:
        return None

    body_full = extract_body(html)
    body, truncated = truncate_body(body_full) if body_full else ("", False)

    return {
        "title": title,
        "date": f"{yyyy:04d}-{mm:02d}-{dd:02d}",
        "body": body,
        "body_truncated": truncated,
    }


def slug_from_article_url(url: str) -> str:
    """URL から page-id を抽出 (例: .../13537.html → 13537)."""
    m = re.search(r"/(\d+)\.html$", url)
    return m.group(1) if m else "0"


# ---------- YAML 出力 ----------


def yaml_escape_str(s: str) -> str:
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def yaml_block_scalar(s: str, indent: int = 2) -> str:
    pad = " " * indent
    lines = s.split("\n")
    head, body = ("|", lines[:-1] if lines and lines[-1] == "" else lines) if s.endswith("\n") else ("|-", lines)
    return head + "\n" + "\n".join(pad + ln for ln in body)


def build_description(article_url: str, body: str, truncated: bool) -> str:
    """description テキストを組み立て.

    本文があれば 本文 + 区切り + リンク。
    本文無し (抽出失敗) の場合は従来通り URL のみ。
    """
    if not body:
        return f"市長ブログ「市政一直線」: {article_url}"
    tail = "（続きはリンク先で）" if truncated else ""
    parts = [body]
    if tail:
        parts.append(tail)
    parts.append(f"市長ブログ「市政一直線」: {article_url}")
    return "\n\n".join(parts)


def build_yaml_doc(uid: str, article_url: str, page_id: str, title: str, date_str: str,
                   body: str, body_truncated: bool,
                   content_hash: str, fetched_at: str | None) -> str:
    lines: list[str] = []
    lines.append(f"uid: {yaml_escape_str(uid)}")
    lines.append(f"summary: {yaml_escape_str(SUMMARY_PREFIX + title)}")
    lines.append(f"url: {yaml_escape_str(article_url)}")
    lines.append(f"dtstart: {yaml_escape_str(date_str)}")
    lines.append(f"dtend: {yaml_escape_str(date_str)}")
    description = build_description(article_url, body, body_truncated)
    lines.append("description: " + yaml_block_scalar(description, indent=2))
    lines.append("")
    lines.append("render:")
    lines.append("  gcal:")
    lines.append(f"    mode: single-allday")
    lines.append("")
    lines.append("source:")
    lines.append(f"  type: {SOURCE_TYPE}")
    lines.append(f"  id: {yaml_escape_str(page_id)}")
    lines.append(f"  url: {yaml_escape_str(article_url)}")
    ts = fetched_at or (datetime.utcnow().isoformat() + "Z")
    lines.append(f"  fetched_at: {yaml_escape_str(ts)}")
    lines.append(f"  content_hash: {yaml_escape_str('sha256-' + content_hash)}")
    return "\n".join(lines) + "\n"


def output_path_for(out_dir: str, uid: str, date_str: str) -> str:
    year_part = date_str[:4]
    md = date_str[5:10]
    fname = f"{md}_{uid.split('@')[0]}.yaml"
    return os.path.join(out_dir, year_part, fname)


# ---------- main ----------


def reiwa_to_gregorian(reiwa_y: int) -> int:
    return 2018 + reiwa_y


def gregorian_to_reiwa(year: int) -> int:
    return year - 2018


def main() -> None:
    here = os.path.dirname(os.path.abspath(__file__))
    default_out_dir = os.path.join(here, "..", "events")

    ap = argparse.ArgumentParser(description="飯能市長ブログ「市政一直線」 → YAML")
    ap.add_argument("--out-dir", default=default_out_dir)
    ap.add_argument("--year", type=int, help="対象西暦 (default: 現在年)")
    ap.add_argument("--uid-prefix", default=DEFAULT_UID_PREFIX)
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--refetch-existing", action="store_true",
                    help="既存 YAML も再 fetch し、content_hash 不一致なら上書き (本文取り込みの backfill 用)")
    ap.add_argument("--min-articles", type=int, default=0,
                    help="抽出 article 数がこれ未満なら exit 2 (default: 0 = 失敗扱いしない)")
    args = ap.parse_args()

    year = args.year or _date.today().year
    reiwa_y = gregorian_to_reiwa(year)

    # 1. top index → 年ページ
    print(f"Fetching top index for 令和{reiwa_y}年 ({year})...", file=sys.stderr)
    top_html = fetch_html(TOP_URL)
    year_url = find_year_page(top_html, reiwa_y)
    if not year_url:
        print(f"No year page found for 令和{reiwa_y}年", file=sys.stderr)
        sys.exit(0)

    # 2. 年ページ → 月ページ list
    year_html = fetch_html(year_url)
    month_pages = find_month_pages(year_html, reiwa_y)
    print(f"Found {len(month_pages)} month pages", file=sys.stderr)

    # 3. 各月ページ → 記事 list → 記事 fetch
    written = 0
    skipped = 0
    unchanged = 0
    for mm, month_url in month_pages:
        if not safe_url(month_url):
            print(f"  skip out-of-allowlist month URL: {month_url}", file=sys.stderr)
            continue
        month_html = fetch_html(month_url)
        articles = find_article_links(month_html)
        print(f"  [令和{reiwa_y}年{mm}月] {len(articles)} articles", file=sys.stderr)

        for article_url, _title_from_index in articles:
            if not safe_url(article_url):
                continue
            page_id = slug_from_article_url(article_url)
            uid = f"{args.uid_prefix}-{page_id}@{UID_NAMESPACE}"

            # 既存 YAML 検索 (idempotent + polite)
            existing_path = _find_existing_by_uid(args.out_dir, uid)
            if existing_path and not args.refetch_existing:
                skipped += 1
                continue

            # 記事 fetch
            try:
                article_html = fetch_html(article_url)
            except Exception as e:
                print(f"    ERROR fetching {article_url}: {e}", file=sys.stderr)
                continue
            parsed = parse_article(article_html)
            if not parsed:
                print(f"    WARN: no title/date in {article_url}", file=sys.stderr)
                continue

            # canonical hash (title + date + body 抜粋)。本文変化を検知する。
            canonical = json.dumps(
                {"title": parsed["title"], "date": parsed["date"],
                 "body": parsed["body"], "body_truncated": parsed["body_truncated"]},
                ensure_ascii=False, sort_keys=True,
            )
            content_hash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:16]

            # 既存 YAML と hash 一致なら fetched_at を流用して diff ゼロ維持
            fetched_at = None
            if existing_path:
                old_hash = _read_content_hash(existing_path)
                old_fetched_at = _read_fetched_at(existing_path)
                if old_hash == f"sha256-{content_hash}":
                    fetched_at = old_fetched_at  # 上書きするが内容同一 → ts も同一
                    unchanged += 1

            doc = build_yaml_doc(uid, article_url, page_id, parsed["title"], parsed["date"],
                                 parsed["body"], parsed["body_truncated"],
                                 content_hash, fetched_at)
            out_path = output_path_for(args.out_dir, uid, parsed["date"])

            if args.dry_run:
                print(f"# === {os.path.relpath(out_path, args.out_dir)} ===")
                print(doc)
                continue

            # 既存 path と新 path が違う (日付変更等) なら旧 path 削除
            if existing_path and os.path.abspath(existing_path) != os.path.abspath(out_path):
                os.remove(existing_path)
            os.makedirs(os.path.dirname(out_path), exist_ok=True)
            with open(out_path, "w", encoding="utf-8") as f:
                f.write(doc)
            verb = "UPDATED" if existing_path else "WROTE"
            print(f"    {verb} {out_path}", file=sys.stderr)
            written += 1

    print(f"Done. articles written={written}  unchanged={unchanged}  skipped (existing)={skipped}", file=sys.stderr)

    if written < args.min_articles and not args.dry_run:
        print(f"FAIL: articles ({written}) < --min-articles ({args.min_articles}).", file=sys.stderr)
        sys.exit(2)


def _find_existing_by_uid(events_dir: str, uid: str) -> str | None:
    """events_dir 配下に uid を含む YAML が既にあるかチェック."""
    import glob
    pattern = os.path.join(events_dir, "**", "*.yaml")
    for path in glob.glob(pattern, recursive=True):
        try:
            with open(path, "r", encoding="utf-8") as f:
                head = f.read(4096)  # 最初の 4KB だけで十分
        except Exception:
            continue
        if uid in head:
            return path
    return None


# _read_yaml_scalar は _lib.read_yaml_scalar に移行 (= 重複削除)
def _read_content_hash(path: str) -> str | None:
    return read_yaml_scalar(path, "content_hash")


def _read_fetched_at(path: str) -> str | None:
    return read_yaml_scalar(path, "fetched_at")


if __name__ == "__main__":
    main()

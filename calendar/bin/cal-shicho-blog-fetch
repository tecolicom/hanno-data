#!/usr/bin/env python3
"""cal-shicho-blog-fetch — 飯能市長ブログ「市政一直線」を YAML 化。

Source: https://www.city.hanno.lg.jp/shiseijoho/shichoshitsu/shichoblog/

階層:
  top                              shichoblog/index.html
  year (令和N年)                   shichoblog/shisei<YYYY>/index.html
  month (令和N年M月)               shichoblog/shisei<YYYY>/shisei<YYYYMM>/index.html
  article (各記事、市長が参加した行事等)  shichoblog/shisei<YYYY>/shisei<YYYYMM>/<page-id>.html

LLM 不使用。当年度の全月を巡回する。

## 2 つの動作モード

### incremental mode (デフォルト、cron 用)
- UID:     shicho-blog-<page-id>-<hash6>@hanno.city.tecoli.com
- dtstart: 取得日 (today, JST)
- 記事の更新日に関係なく「市の site に新規掲載 / 内容が変わった」たびに別 YAML を生成。
- 同 (page_id, content_hash) の YAML が既にあれば skip。
- 記事更新日 (本文の「更新日：」) は source.publish_date に保持。
- バックデート公開 (古い更新日で site に出る) でも、取得日が dtstart になるので
  app トップの「今日以降」ウィンドウに新着として現れる。

### once-per-page mode (legacy、--once-per-page で有効)
- UID:     shicho-blog-<page-id>@hanno.city.tecoli.com
- dtstart: 記事の更新日
- 1 page = 1 YAML。既存 UID があれば再 fetch しない (polite)。
- 新規街 onboarding / 過去分 backfill 用。

politeness: 両モードとも月 index の conditional GET (304) で「変化した月」だけを
巡回する。incremental は非 304 月内の各記事を fetch して hash 判定する。
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.request
from datetime import date as _date, datetime, timezone, timedelta

JST = timezone(timedelta(hours=9))

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _lib import (
    USER_AGENT, UID_NAMESPACE, fetch, fetch_with_cache, read_yaml_scalar,
    load_http_cache, save_http_cache,
    yaml_escape_str, yaml_block_scalar, strip_html, normalize_body,
    reiwa_to_gregorian, gregorian_to_reiwa,
    output_path_for, find_existing_by_uid, load_source_config,
)


# ==================== Source ====================
# 「どこから何を取るか」の city 固有メタ情報は calendar/sources.yaml に外出し済み。
# クローラのコードは都市非依存で、起動時 (import 時) にここで読み込む。
_SRC = load_source_config("shicho-blog")
DEFAULT_UID_PREFIX = _SRC["uid_prefix"]
SOURCE_TYPE = _SRC["source_type"]
SUMMARY_PREFIX = _SRC["summary_prefix"]
TOP_URL = _SRC["top_url"]
URL_HOST_ALLOWLIST = _SRC["url_host_allowlist"]
URL_PATH_PREFIX = _SRC["url_path_prefix"]


# ==================== Tunables ====================
# 本文抽出時の長さ判定 (= 全文 vs 抜粋の境界、目標抜粋字数)。
BODY_FULL_THRESHOLD = 800   # この字数以下なら全文掲載
BODY_EXCERPT_TARGET = 600   # 超過時の目標抜粋字数


# ==================== Logic ====================


def safe_url(url: str) -> bool:
    """allowlist 内の URL のみ許可."""
    return url.startswith(f"https://{URL_HOST_ALLOWLIST}{URL_PATH_PREFIX}")


# ---------- index 巡回 ----------


def find_year_page(top_html: str, reiwa_y: int) -> str | None:
    """top index ページから「市政一直線（令和N年）」へのリンクを探す.

    新しいページは shisei<YYYY>/, 古いものは 1/, 2/ のような番号 path もある。
    令和8年=2026 → /shisei2026/
    """
    label = f"令和{reiwa_y}年"
    pattern = (
        r'href="(https?://[^"]+/shichoblog/[^"]+/index\.html)"[^>]*>市政一直線[（(]\s*'
        + re.escape(label) + r'\s*[）)]'
    )
    m = re.search(pattern, top_html)
    return m.group(1) if m else None


def find_month_pages(year_html: str, reiwa_y: int) -> list[tuple[int, str]]:
    """year index ページから各月へのリンクを取得.

    戻り値: [(month, url), ...] 月昇順
    """
    out: list[tuple[int, str]] = []
    pattern = (
        r'href="(https?://[^"]+/shichoblog/[^"]+/index\.html)"[^>]*>市長ブログ[（(]\s*'
        + re.escape(f"令和{reiwa_y}年") + r'(\d+)月\s*[）)]'
    )
    for m in re.finditer(pattern, year_html):
        url, mm = m.group(1), int(m.group(2))
        out.append((mm, url))
    out.sort()
    return out


def find_article_links(month_html: str) -> list[tuple[str, str]]:
    """month index ページから各記事へのリンクを取得.

    戻り値: [(url, title), ...]
    """
    out: list[tuple[str, str]] = []
    # href=".../shichoblog/<year>/<month>/<digits>.html">記事タイトル</a>
    pattern = r'href="(https?://[^"]+/shichoblog/[^"]+/(\d+)\.html)"[^>]*>([^<]{3,})</a>'
    seen: set[str] = set()
    for m in re.finditer(pattern, month_html):
        url, title = m.group(1), m.group(3).strip()
        if url in seen:
            continue
        seen.add(url)
        out.append((url, title))
    return out


# ---------- article parse ----------


# 「更新日：YYYY年MM月DD日」を anchor して拾う (= 本文 / og:description に含まれる
# 別日付に hit させないため、必ず prefix を要求)。
_DATE_RE = re.compile(r"更新日[：:]\s*(\d{4})年(\d{1,2})月(\d{1,2})日")


def extract_body(html: str) -> str:
    """記事 HTML から本文テキストを抽出.

    `<div class="free-layout-area">` 配下、`<div class="toiawase">` (お問い合わせ先)
    手前まで。h2 の日付見出しは除外 (title 由来情報なので冗長)。
    """
    m = re.search(r'<div class="free-layout-area">([\s\S]*?)(?=<div class="toiawase">|</article>)', html)
    if not m:
        return ""
    block = m.group(1)
    # h2 (日付見出し) は除外
    block = re.sub(r"<h2[^>]*>[\s\S]*?</h2>", "", block)
    # figure / img は除外
    block = re.sub(r"<figure[^>]*>[\s\S]*?</figure>", "", block)
    text = strip_html(block)
    return normalize_body(text)


def truncate_body(body: str, full_threshold: int = BODY_FULL_THRESHOLD,
                  excerpt_target: int = BODY_EXCERPT_TARGET) -> tuple[str, bool]:
    """長さに応じて全文 or 抜粋を返す.

    戻り値: (text, truncated)
    """
    if len(body) <= full_threshold:
        return body, False

    # 段落境界優先
    paragraphs = body.split("\n\n")
    acc: list[str] = []
    total = 0
    for p in paragraphs:
        if acc and total + len(p) + 2 > excerpt_target:
            break
        acc.append(p)
        total += len(p) + 2
    excerpt = "\n\n".join(acc).strip()

    # 段落 1 個ですでに長過ぎる → 句点で切る
    if not excerpt or len(excerpt) > excerpt_target * 1.5:
        first = paragraphs[0]
        cut = -1
        for i in range(min(len(first), excerpt_target + 100), 0, -1):
            if first[i - 1] == "。":
                cut = i
                break
        if cut > 0:
            excerpt = first[:cut]
        else:
            excerpt = first[:excerpt_target]
    return excerpt + "…", True


def parse_article(html: str) -> dict | None:
    """h1 + 更新日 + 本文を抽出して dict 返す.

    戻り値: {"title": str, "date": "YYYY-MM-DD", "body": str, "body_truncated": bool},
            失敗時 (title/date 取れない時) None
    """
    # h1 (空のものをスキップ、最初の意味あるものを採用)
    title: str | None = None
    for m in re.finditer(r"<h1[^>]*>([\s\S]*?)</h1>", html):
        t = re.sub(r"<[^>]+>", "", m.group(1))
        t = re.sub(r"\s+", " ", t).strip()
        if t:
            title = t
            break
    if not title:
        return None

    # 更新日 (本文上部に「更新日：YYYY年MM月DD日」)
    dm = _DATE_RE.search(html)
    if not dm:
        return None
    yyyy, mm, dd = int(dm.group(1)), int(dm.group(2)), int(dm.group(3))
    try:
        _date(yyyy, mm, dd)
    except ValueError:
        return None

    body_full = extract_body(html)
    body, truncated = truncate_body(body_full) if body_full else ("", False)

    return {
        "title": title,
        "date": f"{yyyy:04d}-{mm:02d}-{dd:02d}",
        "body": body,
        "body_truncated": truncated,
    }


def slug_from_article_url(url: str) -> str:
    """URL から page-id を抽出 (例: .../13537.html → 13537)."""
    m = re.search(r"/(\d+)\.html$", url)
    return m.group(1) if m else "0"


# ---------- YAML 出力 ----------


def build_description(article_url: str, body: str, truncated: bool,
                      status_header: str = "") -> str:
    """description テキストを組み立て.

    本文があれば 本文 + 区切り + リンク。
    本文無し (抽出失敗) の場合は従来通り URL のみ。
    status_header: incremental mode で先頭に置く 1 行
                   (例: "📝 市長ブログ更新 (公開日: 2026-06-05)")。
                   content_hash には含めない (= fetch 時点の状態であって本文 identity ではない)。
    """
    header_block = f"{status_header}\n\n" if status_header else ""
    if not body:
        return f"{header_block}市長ブログ「市政一直線」: {article_url}"
    tail = "（続きはリンク先で）" if truncated else ""
    parts = [body]
    if tail:
        parts.append(tail)
    parts.append(f"市長ブログ「市政一直線」: {article_url}")
    return header_block + "\n\n".join(parts)


def build_yaml_doc(uid: str, article_url: str, page_id: str, title: str, date_str: str,
                   body: str, body_truncated: bool,
                   content_hash: str, fetched_at: str | None,
                   status_header: str = "", publish_date: str | None = None) -> str:
    lines: list[str] = []
    lines.append(f"uid: {yaml_escape_str(uid)}")
    lines.append(f"summary: {yaml_escape_str(SUMMARY_PREFIX + title)}")
    lines.append(f"url: {yaml_escape_str(article_url)}")
    lines.append(f"dtstart: {yaml_escape_str(date_str)}")
    lines.append(f"dtend: {yaml_escape_str(date_str)}")
    description = build_description(article_url, body, body_truncated,
                                   status_header=status_header)
    lines.append("description: " + yaml_block_scalar(description, indent=2))
    lines.append("")
    lines.append("render:")
    lines.append("  gcal:")
    lines.append(f"    mode: single-allday")
    lines.append("")
    lines.append("source:")
    lines.append(f"  type: {SOURCE_TYPE}")
    lines.append(f"  id: {yaml_escape_str(page_id)}")
    lines.append(f"  url: {yaml_escape_str(article_url)}")
    ts = fetched_at or (datetime.utcnow().isoformat() + "Z")
    lines.append(f"  fetched_at: {yaml_escape_str(ts)}")
    lines.append(f"  content_hash: {yaml_escape_str('sha256-' + content_hash)}")
    # incremental mode で dtstart を取得日に置き換えた場合に、元の記事更新日を
    # 後追いできるよう保持。once-per-page mode では dtstart == publish_date なので省略。
    if publish_date and publish_date != date_str:
        lines.append(f"  publish_date: {yaml_escape_str(publish_date)}")
    return "\n".join(lines) + "\n"


# ---------- main ----------


def _existing_content_hashes(events_dir: str, uid_prefix: str) -> set[tuple[str, str]]:
    """既存 YAML から (page_id, content_hash) ペアを集める。

    incremental mode の skip 判定に使う。once-per-page と incremental の両形式の
    UID から page_id を抽出する: `shicho-blog-<pid>@...` / `shicho-blog-<pid>-<hash6>@...`。
    """
    import glob
    pattern = os.path.join(events_dir, "**", "*.yaml")
    result: set[tuple[str, str]] = set()
    pid_re = re.compile(rf"^{re.escape(uid_prefix)}-(\d+)(?:-[A-Za-z0-9]+)?@")
    for path in glob.glob(pattern, recursive=True):
        uid = read_yaml_scalar(path, "uid")
        if not uid:
            continue
        m = pid_re.match(uid)
        if not m:
            continue
        page_id = m.group(1)
        ch = read_yaml_scalar(path, "content_hash")
        if not ch:
            continue
        if ch.startswith("sha256-"):
            ch = ch[len("sha256-"):]
        result.add((page_id, ch))
    return result


def main() -> None:
    here = os.path.dirname(os.path.abspath(__file__))
    default_out_dir = os.path.join(here, "..", "events")

    ap = argparse.ArgumentParser(description="飯能市長ブログ「市政一直線」 → YAML")
    ap.add_argument("--out-dir", default=default_out_dir)
    ap.add_argument("--year", type=int, help="対象西暦 (default: 現在年)")
    ap.add_argument("--uid-prefix", default=DEFAULT_UID_PREFIX)
    ap.add_argument("--dry-run", action="store_true")
    ap.add_argument("--refetch-existing", action="store_true",
                    help="既存 YAML も再 fetch し、content_hash 不一致なら上書き (本文取り込みの backfill 用)")
    ap.add_argument("--once-per-page", action="store_true",
                    help="legacy mode: 1 page = 1 YAML、dtstart = 記事更新日。"
                         "新規街 onboarding / 過去分 backfill 用。"
                         "デフォルトは incremental mode (新規・内容変化ごとに別 YAML、dtstart=今日)")
    ap.add_argument("--min-articles", type=int, default=0,
                    help="抽出 article 数がこれ未満なら exit 2 (default: 0 = 失敗扱いしない)")
    args = ap.parse_args()

    # incremental mode 用: 既存 YAML の (page_id, content_hash) を pre-scan。
    # + 同 page_id に YAML が 1 件でもあれば「既知 page」= 内容更新扱い。
    existing_hashes: set[tuple[str, str]] = set()
    existing_page_ids: set[str] = set()
    if not args.once_per_page:
        existing_hashes = _existing_content_hashes(args.out_dir, args.uid_prefix)
        existing_page_ids = {pid for (pid, _) in existing_hashes}

    today_jst = datetime.now(JST).strftime("%Y-%m-%d")

    year = args.year or _date.today().year
    reiwa_y = gregorian_to_reiwa(year)

    # 1. top index → 年ページ
    # HTTP Conditional GET: year / month index は新月 / 新記事追加で変化。
    # TOP は年リスト固定で cache 効果薄なので素 fetch。
    http_cache = load_http_cache()

    def fetch_cached(url: str) -> str | None:
        """body str or None (= 304). Updates http_cache in-place on 200."""
        entry = http_cache.get(url, {})
        body, etag, lm = fetch_with_cache(url, entry.get("etag"), entry.get("last_modified"))
        if body is not None:
            http_cache[url] = {"etag": etag, "last_modified": lm}
        return body

    print(f"Fetching top index for 令和{reiwa_y}年 ({year})...", file=sys.stderr)
    top_html = fetch(TOP_URL)
    year_url = find_year_page(top_html, reiwa_y)
    if not year_url:
        print(f"No year page found for 令和{reiwa_y}年", file=sys.stderr)
        sys.exit(0)

    # 2. 年ページ → 月ページ list
    # year は新月リンク追加 (= 月初) で変化するが、月途中の記事追加は
    # year に反映されない (= month index だけ変わる)。なので year 304 でも
    # 早期 return せず、各 month の 304 判定に委ねる。
    # year は year_url 自体は固定 (例: shisei2026/index.html) なので、
    # 304 時は month list を「既知の月 URL」から再構築する必要がある。
    # 簡単化: year 304 でも year_url は fetch (= 1 リクエスト無駄)。
    year_html = fetch(year_url)
    month_pages = find_month_pages(year_html, reiwa_y)
    print(f"Found {len(month_pages)} month pages", file=sys.stderr)

    # 3. 各月ページ → 記事 list → 記事 fetch
    written = 0
    skipped = 0
    unchanged = 0
    cache_skipped = 0
    for mm, month_url in month_pages:
        if not safe_url(month_url):
            print(f"  skip out-of-allowlist month URL: {month_url}", file=sys.stderr)
            continue
        # month は新記事追加で変化 → 304 なら articles 巡回不要
        month_html = fetch_cached(month_url)
        if month_html is None:
            cache_skipped += 1
            continue
        articles = find_article_links(month_html)
        print(f"  [令和{reiwa_y}年{mm}月] {len(articles)} articles", file=sys.stderr)

        for article_url, _title_from_index in articles:
            if not safe_url(article_url):
                continue
            page_id = slug_from_article_url(article_url)

            # once-per-page: 記事 fetch 前に既存 UID で skip (polite)
            if args.once_per_page:
                uid = f"{args.uid_prefix}-{page_id}@{UID_NAMESPACE}"
                existing_path = find_existing_by_uid(args.out_dir, uid)
                if existing_path and not args.refetch_existing:
                    skipped += 1
                    continue
            else:
                existing_path = None  # incremental: hash 計算後に決定

            # 記事 fetch (両モード共通)
            try:
                article_html = fetch(article_url)
            except Exception as e:
                print(f"    ERROR fetching {article_url}: {e}", file=sys.stderr)
                continue
            parsed = parse_article(article_html)
            if not parsed:
                print(f"    WARN: no title/date in {article_url}", file=sys.stderr)
                continue

            # canonical hash (title + date + body 抜粋)。本文変化を検知する。
            # date は記事更新日 (= content identity)。dtstart が取得日でも不変。
            canonical = json.dumps(
                {"title": parsed["title"], "date": parsed["date"],
                 "body": parsed["body"], "body_truncated": parsed["body_truncated"]},
                ensure_ascii=False, sort_keys=True,
            )
            content_hash = hashlib.sha256(canonical.encode("utf-8")).hexdigest()[:16]

            if args.once_per_page:
                # legacy: dtstart=記事更新日、UID=prefix-pid、hash 一致なら fetched_at 流用
                fetched_at = None
                if existing_path:
                    old_hash = _read_content_hash(existing_path)
                    old_fetched_at = _read_fetched_at(existing_path)
                    if old_hash == f"sha256-{content_hash}":
                        fetched_at = old_fetched_at  # 上書きするが内容同一 → ts も同一
                        unchanged += 1
                uid = f"{args.uid_prefix}-{page_id}@{UID_NAMESPACE}"
                dtstart = parsed["date"]
                publish_date = None
                status_header = ""
            else:
                # incremental: (page_id, content_hash) が既知なら skip (新規/変更のみ書く)
                if (page_id, content_hash) in existing_hashes:
                    unchanged += 1
                    continue
                uid = f"{args.uid_prefix}-{page_id}-{content_hash[:6]}@{UID_NAMESPACE}"
                dtstart = today_jst
                publish_date = parsed["date"]
                fetched_at = None
                # status: 同 page_id に既存 YAML 無し → 新規 / 既存あり → 内容更新
                if page_id in existing_page_ids:
                    status_header = f"🔄 内容更新 (公開日: {publish_date})"
                else:
                    status_header = f"📝 市長ブログ更新 (公開日: {publish_date})"

            doc = build_yaml_doc(uid, article_url, page_id, parsed["title"], dtstart,
                                 parsed["body"], parsed["body_truncated"],
                                 content_hash, fetched_at,
                                 status_header=status_header, publish_date=publish_date)
            out_path = output_path_for(args.out_dir, uid, dtstart)

            if args.dry_run:
                print(f"# === {os.path.relpath(out_path, args.out_dir)} ===")
                print(doc)
                continue

            # 既存 path と新 path が違う (日付変更等) なら旧 path 削除
            if existing_path and os.path.abspath(existing_path) != os.path.abspath(out_path):
                os.remove(existing_path)
            os.makedirs(os.path.dirname(out_path), exist_ok=True)
            with open(out_path, "w", encoding="utf-8") as f:
                f.write(doc)
            # incremental では次の loop iter 内でも自身を skip 対象にできるよう set 更新
            if not args.once_per_page:
                existing_hashes.add((page_id, content_hash))
                existing_page_ids.add(page_id)
            verb = "UPDATED" if existing_path else "WROTE"
            print(f"    {verb} {out_path}", file=sys.stderr)
            written += 1

    save_http_cache(http_cache)
    print(f"Done. articles written={written}  unchanged={unchanged}  "
          f"skipped (existing)={skipped}  months (304)={cache_skipped}",
          file=sys.stderr)

    if written < args.min_articles and not args.dry_run:
        print(f"FAIL: articles ({written}) < --min-articles ({args.min_articles}).", file=sys.stderr)
        sys.exit(2)




# _read_yaml_scalar は _lib.read_yaml_scalar に移行 (= 重複削除)
def _read_content_hash(path: str) -> str | None:
    return read_yaml_scalar(path, "content_hash")


def _read_fetched_at(path: str) -> str | None:
    return read_yaml_scalar(path, "fetched_at")


if __name__ == "__main__":
    main()
